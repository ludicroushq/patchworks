{
  "name": "@patchworks/repo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.8"
  },
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "overrides": {
    "postcss": "8.5.21",
    "sharp": "0.35.3"
  },
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "check": "bun run lint && bun run typecheck && bun run build && bun run test:coverage && bun tooling/package-artifacts.ts",
    "clean": "turbo run clean && rm -rf node_modules packages/*/node_modules docs/node_modules .turbo coverage",
    "dev": "turbo run dev --filter=patchworks --filter=@patchworks/docs",
    "dev:docs": "turbo run dev --filter=@patchworks/docs...",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "preview:publish": "pkg-pr-new publish --comment=update --packageManager=bun './packages/patchworks'",
    "release": "bun run build && bun tooling/package-artifacts.ts && changeset publish",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck && tsc --project tsconfig.test.json --noEmit",
    "version": "changeset version && bun install"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/cli": "^2.31.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "oxlint": "^1.75.0",
    "pkg-pr-new": "^0.0.75",
    "publint": "^0.3.21",
    "tsdown": "^0.21.10",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "vitest": "4.1.10"
  }
}
